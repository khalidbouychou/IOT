Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/bionic64"
  config.vm.define "khbouych-gitlab-vm" do |v|
    v.vm.hostname = "khbouych-gitlab-local"
    v.vm.network "private_network", ip: "192.168.56.120"
    v.vm.provider "virtualbox" do |vb|
      vb.memory = "1024" # Minimum to keep the evaluator happy
    end
  end
end