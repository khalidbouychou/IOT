# ============================================
# Copy this file to .env and update values
# cp .env.example .env
# ============================================

# ============================================
# Part 1: K3s Cluster Configuration
# ============================================
P1_SERVER_IP=192.168.56.110
P1_SERVER_HOSTNAME=khbouyS
P1_WORKER_IP=192.168.56.111
P1_WORKER_HOSTNAME=khbouyW
P1_MEMORY=1024
P1_CPUS=1

# ============================================
# Part 2: K3s Applications Configuration
# ============================================
P2_SERVER_IP=192.168.56.110
P2_SERVER_HOSTNAME=khbouyS
P2_MEMORY=1024
P2_CPUS=1

# ============================================
# Part 3: K3d and Argo CD Configuration
# ============================================
P3_CLUSTER_NAME=khbouy
P3_AGENTS=2
P3_APP_PORT=8888
P3_ARGOCD_PORT=8080

# GitHub Configuration - REQUIRED FOR PART 3
# Create a token at: https://github.com/settings/tokens
GITHUB_REPO_URL=https://github.com/khalidbouychou/khbouy-iot
GITHUB_REPO_BRANCH=master
GITHUB_DEPLOYMENT_PATH=k3d
GITHUB_TOKEN=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

# ============================================
# Bonus: GitLab Integration Configuration
# ============================================
BONUS_CLUSTER_NAME=khbouy-gitlab
BONUS_AGENTS=3
BONUS_MEMORY=4096
BONUS_CPUS=4

# GitLab Configuration - REQUIRED FOR BONUS
GITLAB_DOMAIN=khbouy.local
GITLAB_ADMIN_EMAIL=root@khbouy.local

# Argo CD GitLab Integration - REQUIRED FOR BONUS 
ARGOCD_GITLAB_REPO_URL=http://gitlab.khbouy.local/root/khbouy-iot.git
ARGOCD_GITLAB_TOKEN=glpat-oXfxssOeS0hJ6T1Xec7iuWM6MQpvOjEKdTo0czM2ag8.01.170bm51ep
ARGOCD_GITLAB_USERNAME=root

# ============================================
# Digital Ocean Configuration - OPTIONAL
# ============================================
# Get token from: https://cloud.digitalocean.com/account/api/tokens
DO_API_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DO_CLUSTER_NAME=khbouy-production
DO_REGION=nyc3

# Domain for DO - REQUIRED IF USING DIGITAL OCEAN
DO_DOMAIN=yourdomain.com
DO_GITLAB_DOMAIN=gitlab.yourdomain.com
DO_ARGOCD_DOMAIN=argocd.yourdomain.com
CERT_MANAGER_EMAIL=admin@yourdomain.com

# ============================================
# Container Registry - OPTIONAL
# ============================================
DOCKER_HUB_USERNAME=your_username
DOCKER_HUB_PASSWORD=your_password
